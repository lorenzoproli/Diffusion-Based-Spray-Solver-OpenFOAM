#!/bin/bash
set -euo pipefail

NP=16

log() { echo "[$(date '+%H:%M:%S')] $*"; }

log "=== Clean ==="
rm -rf processor*
rm -f log.*
# Rimuove time-dir precedenti (0.0005, 0.001, ...) ma mantiene 0/ (condizioni iniziali)
rm -rf 0.[0-9]* [1-9]*

# Ripristina U pulita (BC only) prima di potentialFoam
cp U_backup/U 0/U

# ------------------------------------------------------------------
# INIT: potentialFoam
# ------------------------------------------------------------------
log "=== potentialFoam ==="
potentialFoam -noFunctionObjects 2>&1 | tee log.potentialFoam

# ------------------------------------------------------------------
# DECOMPOSE
# ------------------------------------------------------------------
log "=== decomposePar ==="
decomposePar 2>&1 | tee log.decomposePar

# ------------------------------------------------------------------
# RUN sprayFoam (UNICA FASE)
# ------------------------------------------------------------------
log "=== sprayFoam RUN ==="
mpirun -np $NP sprayFoamDBM -parallel 2>&1 | tee log.sprayFoamDBM

# ------------------------------------------------------------------
# POST
# ------------------------------------------------------------------
log "=== reconstruct ==="
reconstructPar 2>&1 | tee log.reconstructPar

log "=== DONE ==="