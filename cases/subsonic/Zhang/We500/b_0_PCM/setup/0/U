FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// U_inf = 62.5 m/s in direzione crossflow (X)

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (62.5 0 0);

boundaryField
{
    gasInlet
    {
        type            fixedValue;
        value           uniform (62.5 0 0);
    }

    outletRight
    {
        type            pressureInletOutletVelocity;
        inletValue      uniform (0 0 0);    // backflow a vel nulla
        value           uniform (62.5 0 0);
    }

    outletTop
    {
        type            pressureInletOutletVelocity;
        inletValue      uniform (0 0 0);    // backflow a vel nulla
        value           uniform (62.5 0 0);
    }

    bottomWall
    {
        type            noSlip;
    }

    filmTopWall
    {
        type            noSlip;
    }

    stepWall
    {
        type            noSlip;
    }

    front
    {
        type            symmetryPlane;
    }

    back
    {
        type            symmetryPlane;
    }
}

