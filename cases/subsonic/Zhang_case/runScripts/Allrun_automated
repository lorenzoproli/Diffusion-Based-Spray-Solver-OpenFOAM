#!/bin/bash
set -euo pipefail

NP=16

log() { echo "[$(date '+%H:%M:%S')] $*"; }

log "=== Clean ==="
rm -rf processor*
rm -f log.*

# ------------------------------------------------------------------
# RESTORE initial U from backup (uniform IC, mesh-independent)
# ------------------------------------------------------------------
log "=== restore U from U_backup ==="
cp U_backup/U 0/U

# ------------------------------------------------------------------
# INIT: potentialFoam
# ------------------------------------------------------------------
log "=== potentialFoam ==="
potentialFoam -noFunctionObjects 2>&1 | tee log.potentialFoam

# ------------------------------------------------------------------
# DECOMPOSE
# ------------------------------------------------------------------
log "=== decomposePar ==="
decomposePar 2>&1 | tee log.decomposePar

# ------------------------------------------------------------------
# RUN sprayFoam (UNICA FASE)
# ------------------------------------------------------------------
log "=== sprayFoam RUN ==="
mpirun -np $NP sprayFoam -parallel 2>&1 | tee log.sprayFoam

# ------------------------------------------------------------------
# POST
# ------------------------------------------------------------------
log "=== reconstruct ==="
reconstructPar 2>&1 | tee log.reconstructPar

log "=== DONE ==="