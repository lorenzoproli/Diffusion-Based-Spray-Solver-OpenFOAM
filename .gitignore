# ============================================================
# OpenFOAM - general
# ============================================================

# Time directories (numerical results)
[1-9]*/
[1-9]*.[0-9]*/
0.*
!0.orig/
!0/
!0.org/

# Processor directories (parallel runs)
processor*/
processors*/

# Logs
log.*
*.log

# Mesh and decomposition
constant/polyMesh/points
constant/polyMesh/faces
constant/polyMesh/owner
constant/polyMesh/neighbour
constant/polyMesh/boundary

# Dynamic mesh / runtime-generated data
constant/polyMesh/sets
constant/polyMesh/cellZones
constant/polyMesh/faceZones
constant/polyMesh/pointZones

# Function objects output
postProcessing/
forces/
probes/
surfaces/

# Allow curated case-local postProcessing assets (figures, tables, paraview)
# under cases/**/postProcessing/. Heavy generated outputs are still excluded
# below via the explicit *.vtk, *.vtu, *.foam, *.dat, *.raw, log.* rules.
!cases/**/postProcessing/
!cases/**/postProcessing/**

# Reconstruction / sampling
sets/
surfaces/

# ============================================================
# Case-specific generated files
# ============================================================

# Decomposition and reconstruction
decomposeParDict
reconstructPar*

# Restart and backup files
*~
*.bak
*.old
*.tmp

# ============================================================
# Large numerical outputs
# ============================================================

# Binary and field data
*.foam
*.vtk
*.vtu
*.raw
*.dat

# Compressed results
*.gz
*.zip
*.tar
*.tar.gz
*.7z

# ============================================================
# Python / scripting
# ============================================================

__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv

# ============================================================
# OS / editor
# ============================================================

.DS_Store
Thumbs.db
.vscode/
.idea/
*:Zone.Identifier

# ============================================================
# Documentation build artifacts
# ============================================================

*.aux
*.log
*.out
*.toc
*.synctex.gz

# ============================================================
# OpenFOAM libraries (src/)
# ============================================================

# Build artifacts
src/**/lnInclude/
src/**/platforms/
src/**/Make/linux*
src/**/Make/*Opt
src/**/Make/*Debug

# Compilation logs
src/**/log.*

# -------------------------------------------------------------------------
# Thesis LaTeX workspace
# -------------------------------------------------------------------------
thesis/**/*.aux
thesis/**/*.bbl
thesis/**/*.bcf
thesis/**/*.blg
thesis/**/*.fdb_latexmk
thesis/**/*.fls
thesis/**/*.lof
thesis/**/*.log
thesis/**/*.lot
thesis/**/*.out
thesis/**/*.run.xml
thesis/**/*.synctex.gz
thesis/**/*.toc
thesis/**/*.nav
thesis/**/*.snm
thesis/**/*.vrb
thesis/**/*-blx.bib

# Generated thesis PDFs
thesis/**/*.pdf
!thesis/Template_tesi.pdf

# Local Claude state for thesis
thesis/.claude/local/
thesis/.claude/settings.local.json
